#!/usr/bin/env bash
msg=$(cat "$1")
if ! echo "$msg" | grep -Eq '^(feat|fix|docs|refactor|test|chore|style|perf|session|discover|design|verify|release|retro): .+'; then
  echo "[harness] Commit message should use: <type>: <description>"
  echo "           type: feat / fix / docs / refactor / test / chore / style / perf / session"
  echo "                 discover / design / verify / release / retro"
fi
exit 0
